{
  "name": "kick-save",
  "version": "1.0.0",
  "description": "Kick.com stream downloader — VODs, clips, live, chat",
  "main": "src/index.js",
  "bin": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "build:win": "pkg . --target node18-win-x64 --output dist/kick-save.exe --compress GZip",
    "build:linux": "pkg . --target node18-linux-x64 --output dist/kick-save-linux"
  },
  "pkg": {
    "assets": ["src/**/*"],
    "targets": ["node18-win-x64"]
  },
  "dependencies": {
    "axios": "^1.7.2",
    "chalk": "^4.1.2",
    "cli-progress": "^3.12.0",
    "commander": "^12.1.0",
    "inquirer": "^8.2.6",
    "ws": "^8.18.0"
  }
}
